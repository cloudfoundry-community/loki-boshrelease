#!/usr/bin/env bash
set -euo pipefail

# Copy common utils
mkdir -p ${BOSH_INSTALL_TARGET}/common
cp -a ${BOSH_COMPILE_TARGET}/common/* ${BOSH_INSTALL_TARGET}/common

# Copy Alloy binary
mkdir -p "${BOSH_INSTALL_TARGET}/bin"
cp -a alloy-linux64-* "${BOSH_INSTALL_TARGET}/bin/alloy"
chmod +x "${BOSH_INSTALL_TARGET}/bin/alloy"
