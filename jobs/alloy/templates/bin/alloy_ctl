#!/usr/bin/env bash

set -eu

RUN_DIR=/var/vcap/sys/run/alloy
LOG_DIR=/var/vcap/sys/log/alloy
TMP_DIR=/var/vcap/sys/tmp/alloy
STORAGE_PATH=<%= p('alloy.storage.path') %>
mkdir -p ${RUN_DIR} ${LOG_DIR} ${TMP_DIR} ${STORAGE_PATH}

PIDFILE=${RUN_DIR}/alloy.pid

# shellcheck source=../../../../src/common/utils.sh
source /var/vcap/packages/alloy/common/utils.sh
exec 1>> "${LOG_DIR}/$(basename "$0").stdout.log"
exec 2>> "${LOG_DIR}/$(basename "$0").stderr.log"

export PATH=/var/vcap/packages/alloy/bin:${PATH}

case $1 in
  start)
    pid_guard ${PIDFILE} "alloy"
    echo $$ > ${PIDFILE}

    exec alloy run \
      --storage.path=${STORAGE_PATH} \
      /var/vcap/jobs/alloy/config/config.alloy \
      >>  ${LOG_DIR}/alloy.stdout.log \
      2>> ${LOG_DIR}/alloy.stderr.log
    ;;

  stop)
    kill_and_wait ${PIDFILE}
    ;;

  *)
    echo "Usage: $0 {start|stop}"
    exit 1
  ;;

esac
exit 0
